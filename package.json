{
  "name": "jiu-jitsu-shenanigans",
  "version": "1.0.0",
  "description": "A fun Jiu-Jitsu training companion app with random technique generator, round timer, and belt tracker.",
  "main": "index.js",
  "scripts": {
    "start": "npx serve www",
    "build": "echo 'Static web app - no build step needed'",
    "cap:init": "npx cap init 'Jiu-Jitsu Shenanigans' com.shenanigans.jiujitsu",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:build:apk": "npx cap build android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "serve": "^14.2.3"
  },
  "keywords": ["jiu-jitsu", "bjj", "martial-arts", "android", "capacitor"],
  "author": "Jiu-Jitsu Shenanigans",
  "license": "MIT"
}
